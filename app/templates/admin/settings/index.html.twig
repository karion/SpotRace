{% extends 'base.html.twig' %}

{% block title %}Ustawienia globalne{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3">Ustawienia globalne</h1>
            <p><a href="{{ path('app_admin_user_index') }}">&larr; Wróć do panelu admina</a></p>

            <form method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('admin-settings') }}">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle">
                        <thead><tr><th>Grupa</th><th>Ustawienie</th><th>Wartość domyślna</th></tr></thead>
                        <tbody>
                            {% for row in settings %}
                                {% set setting = row.setting %}
                                <tr>
                                    <td>{{ setting.group }}</td>
                                    <td>
                                        <div class="fw-semibold">{{ setting.label }}</div>
                                        {% if setting.description %}
                                            <div class="text-secondary small">{{ setting.description }}</div>
                                        {% endif %}
                                        <code class="small">{{ setting.key }}</code>
                                    </td>
                                    <td>
                                        {% if setting.type == 'bool' %}
                                            <input class="form-check-input" type="checkbox" name="value[{{ setting.key }}]" value="1" {% if row.value == '1' %}checked{% endif %}>
                                        {% else %}
                                            <input class="form-control" name="value[{{ setting.key }}]" value="{{ row.value }}">
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <button class="btn btn-primary" type="submit">Zapisz ustawienia</button>
            </form>
        </div>
    </main>
{% endblock %}
