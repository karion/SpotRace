{% extends 'base.html.twig' %}

{% block title %}Edycja firmy{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3">Edytuj firmę: {{ company.name }}</h1>
            <p><a href="{{ path('app_admin_company_index') }}">&larr; Wróć do listy firm</a></p>

            {{ form_start(editForm) }}
                {{ form_row(editForm.name) }}
                {{ form_row(editForm.slug) }}
                {{ form_row(editForm.allowedEmailDomains) }}
                {{ form_row(editForm.passwordMinLength) }}
                <div class="row">
                    <div class="col-md-3">{{ form_row(editForm.passwordRequireLowercase) }}</div>
                    <div class="col-md-3">{{ form_row(editForm.passwordRequireUppercase) }}</div>
                    <div class="col-md-3">{{ form_row(editForm.passwordRequireDigit) }}</div>
                    <div class="col-md-3">{{ form_row(editForm.passwordRequireSpecial) }}</div>
                </div>
                {{ form_row(editForm.save) }}
            {{ form_end(editForm) }}

            <h2 class="h5 mt-4">Linki rejestracyjne</h2>
            <form method="post" action="{{ path('app_admin_company_token_create', {id: company.id}) }}" class="mb-3">
                <input type="hidden" name="_token" value="{{ csrf_token('admin-company-' ~ company.id) }}">
                <button class="btn btn-primary btn-sm" type="submit">Wygeneruj link 48h</button>
            </form>
            {% if tokens is empty %}
                <p>Brak linków rejestracyjnych.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead><tr><th>Link</th><th>Wygasa</th><th>Status</th><th>Akcje</th></tr></thead>
                        <tbody>
                            {% for token in tokens %}
                                <tr>
                                    <td><code>{{ registrationLinks[token.id] }}</code></td>
                                    <td>{{ token.expiresAt|date('Y-m-d H:i') }}</td>
                                    <td>{{ token.revokedAt ? 'unieważniony' : (token.expiresAt < date() ? 'wygasły' : 'aktywny') }}</td>
                                    <td>
                                        {% if not token.revokedAt %}
                                            <form method="post" action="{{ path('app_admin_company_token_revoke', {token: token.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('company-token-' ~ token.id) }}">
                                                <button class="btn btn-outline-danger btn-sm" type="submit">Unieważnij</button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
