{% extends 'base.html.twig' %}

{% block title %}Przypisanie miejsca{% endblock %}

{% block body %}
    <main class="card">
        <h1>Przypisz miejsce: {{ spot.name }}</h1>
        <p><a href="{{ path('app_admin_parking_spot_index') }}">&larr; Wróć do listy miejsc</a></p>

        <form method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('assign-spot-' ~ spot.id) }}">
            <label for="assigned_user_id">Użytkownik</label>
            <select id="assigned_user_id" name="assigned_user_id" required>
                {% for managedUser in users %}
                    <option value="{{ managedUser.id }}">{{ managedUser.name }} ({{ managedUser.email }})</option>
                {% endfor %}
            </select>

            <label for="starts_at">Data od</label>
            <input id="starts_at" type="date" name="starts_at" value="{{ "now"|date('Y-m-d') }}" required>

            <label for="ends_at">Data do (opcjonalnie)</label>
            <input id="ends_at" type="date" name="ends_at">

            <button type="submit">Zapisz przypisanie</button>
        </form>

        <h2>Historia przypisań</h2>
        {% if assignments is empty %}
            <p>Brak przypisań.</p>
        {% else %}
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Użytkownik</th>
                        <th>Przypisał</th>
                        <th>Zakres</th>
                    </tr>
                </thead>
                <tbody>
                    {% for assignment in assignments %}
                        <tr>
                            <td>{{ assignment.assignedUser.name }} ({{ assignment.assignedUser.email }})</td>
                            <td>{{ assignment.assignedByUser.name }}</td>
                            <td>
                                {{ assignment.startsAt|date('Y-m-d') }}
                                -
                                {{ assignment.endsAt ? assignment.endsAt|date('Y-m-d') : 'bezterminowo' }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </main>
{% endblock %}
