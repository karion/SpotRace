{% extends 'base.html.twig' %}

{% block title %}Przypisanie miejsca{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            {% set isEditing = editingAssignment is defined and editingAssignment %}

            <h1 class="h3">Przypisz miejsce: {{ spot.name }}</h1>
            <p><a href="{{ path('app_admin_parking_spot_index') }}">&larr; Wróć do listy miejsc</a></p>

            <form method="post" action="{{ isEditing ? path('app_admin_parking_spot_assignment_edit', {assignment: editingAssignment.id}) : path('app_admin_parking_spot_assign', {id: spot.id}) }}" class="vstack gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token(isEditing ? 'edit-assignment-' ~ editingAssignment.id : 'assign-spot-' ~ spot.id) }}">
                <div>
                    <label class="form-label" for="assigned_user_id">Użytkownik</label>
                    <select class="form-select" id="assigned_user_id" name="assigned_user_id" required>
                        {% for managedUser in users %}
                            <option value="{{ managedUser.id }}" {{ isEditing and editingAssignment.assignedUser.id == managedUser.id ? 'selected' : '' }}>{{ managedUser.name }} ({{ managedUser.email }})</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="form-label" for="starts_at">Data od</label>
                    <input class="form-control" id="starts_at" type="date" name="starts_at" value="{{ isEditing ? editingAssignment.startsAt|date('Y-m-d') : "now"|date('Y-m-d') }}" required>
                </div>

                <div>
                    <label class="form-label" for="ends_at">Data do (opcjonalnie)</label>
                    <input class="form-control" id="ends_at" type="date" name="ends_at" value="{{ isEditing and editingAssignment.endsAt ? editingAssignment.endsAt|date('Y-m-d') : '' }}">
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">{{ isEditing ? 'Zapisz zmiany' : 'Zapisz przypisanie' }}</button>
                    {% if isEditing %}
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin_parking_spot_assign', {id: spot.id}) }}">Anuluj edycję</a>
                    {% endif %}
                </div>
            </form>

            <h2 class="h5 mt-4">Historia przypisań</h2>
            {% if assignments is empty %}
                <p class="mb-0">Brak przypisań.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Użytkownik</th>
                                <th>Przypisał</th>
                                <th>Zakres</th>
                                <th class="text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for assignment in assignments %}
                                <tr>
                                    <td>{{ assignment.assignedUser.name }} ({{ assignment.assignedUser.email }})</td>
                                    <td>{{ assignment.assignedByUser.name }}</td>
                                    <td>
                                        {{ assignment.startsAt|date('Y-m-d') }}
                                        -
                                        {{ assignment.endsAt ? assignment.endsAt|date('Y-m-d') : 'bezterminowo' }}
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2">
                                            <a class="btn btn-outline-light btn-sm" href="{{ path('app_admin_parking_spot_assignment_edit', {assignment: assignment.id}) }}">Edytuj</a>
                                            <form method="post" action="{{ path('app_admin_parking_spot_assignment_delete', {assignment: assignment.id}) }}" onsubmit="return confirm('Usunąć przypisanie?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-assignment-' ~ assignment.id) }}">
                                                <button class="btn btn-outline-danger btn-sm" type="submit">Usuń</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
