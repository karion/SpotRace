{% extends 'base.html.twig' %}

{% block title %}Przypisanie miejsca{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3">Przypisz miejsce: {{ spot.name }}</h1>
            <p><a href="{{ path('app_admin_parking_spot_index') }}">&larr; Wróć do listy miejsc</a></p>

            <form method="post" class="vstack gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token('assign-spot-' ~ spot.id) }}">
                <div>
                    <label class="form-label" for="assigned_user_id">Użytkownik</label>
                    <select class="form-select" id="assigned_user_id" name="assigned_user_id" required>
                        {% for managedUser in users %}
                            <option value="{{ managedUser.id }}">{{ managedUser.name }} ({{ managedUser.email }})</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="form-label" for="starts_at">Data od</label>
                    <input class="form-control" id="starts_at" type="date" name="starts_at" value="{{ "now"|date('Y-m-d') }}" required>
                </div>

                <div>
                    <label class="form-label" for="ends_at">Data do (opcjonalnie)</label>
                    <input class="form-control" id="ends_at" type="date" name="ends_at">
                </div>

                <button class="btn btn-primary" type="submit">Zapisz przypisanie</button>
            </form>

            <h2 class="h5 mt-4">Historia przypisań</h2>
            {% if assignments is empty %}
                <p class="mb-0">Brak przypisań.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Użytkownik</th>
                                <th>Przypisał</th>
                                <th>Zakres</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for assignment in assignments %}
                                <tr>
                                    <td>{{ assignment.assignedUser.name }} ({{ assignment.assignedUser.email }})</td>
                                    <td>{{ assignment.assignedByUser.name }}</td>
                                    <td>
                                        {{ assignment.startsAt|date('Y-m-d') }}
                                        -
                                        {{ assignment.endsAt ? assignment.endsAt|date('Y-m-d') : 'bezterminowo' }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
