{% extends 'base.html.twig' %}

{% block title %}Panel admina - miejsca postojowe{% endblock %}

{% block body %}
    <main class="card">
        <h1>Panel administratora — miejsca postojowe</h1>

        <h2>Dodaj nowe miejsce</h2>
        {{ form_start(createForm) }}
            {{ form_row(createForm.name) }}
            {{ form_row(createForm.description) }}
            {{ form_row(createForm.save) }}
        {{ form_end(createForm) }}

        <h2>Lista miejsc</h2>
        {% if spots is empty %}
            <p>Brak dodanych miejsc postojowych.</p>
        {% else %}
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nazwa</th>
                        <th>Opis</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    {% for spot in spots %}
                        <tr>
                            <td>{{ spot.name }}</td>
                            <td>{{ spot.description|nl2br }}</td>
                            <td>
                                <a class="button-link" href="{{ path('app_admin_parking_spot_edit', {id: spot.id}) }}">Edytuj</a>
                                <form class="inline-form" method="post" action="{{ path('app_admin_parking_spot_delete', {id: spot.id}) }}" onsubmit="return confirm('Usunąć miejsce postojowe?');">
                                    <button class="danger-btn" type="submit">Usuń</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </main>
{% endblock %}
