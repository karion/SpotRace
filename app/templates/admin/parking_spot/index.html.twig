{% extends 'base.html.twig' %}

{% block title %}Panel admina - miejsca postojowe{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3">Panel administratora — miejsca postojowe</h1>
            <p><a class="btn btn-outline-light btn-sm" href="{{ path('app_admin_user_index') }}">Przejdź do zarządzania użytkownikami</a></p>

            <h2 class="h5 mt-4">Dodaj nowe miejsce</h2>
            {{ form_start(createForm) }}
                {{ form_row(createForm.name) }}
                {{ form_row(createForm.description) }}
                {{ form_row(createForm.save) }}
            {{ form_end(createForm) }}

            <h2 class="h5 mt-4">Lista miejsc</h2>
            {% if spots is empty %}
                <p class="mb-0">Brak dodanych miejsc postojowych.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Nazwa</th>
                                <th>Opis</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for spot in spots %}
                                <tr>
                                    <td>{{ spot.name }}</td>
                                    <td>{{ spot.description|nl2br }}</td>
                                    <td>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a class="btn btn-primary btn-sm" href="{{ path('app_admin_parking_spot_edit', {id: spot.id}) }}">Edytuj</a>
                                            <a class="btn btn-outline-light btn-sm" href="{{ path('app_admin_parking_spot_assign', {id: spot.id}) }}">Przypisania</a>
                                            <form method="post" action="{{ path('app_admin_parking_spot_delete', {id: spot.id}) }}" onsubmit="return confirm('Usunąć miejsce postojowe?');">
                                                <button class="btn btn-danger btn-sm" type="submit">Usuń</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
