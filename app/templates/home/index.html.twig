{% extends 'base.html.twig' %}

{% block title %}SpotRace - panel{% endblock %}

{% block body %}
    <main class="card">
        <h1>Witaj, {{ user ? user.name : 'gościu' }}!</h1>
        <p>Jesteś zalogowany do aplikacji.</p>
        <p>Twoje role: {{ user ? user.roles|join(', ') : '' }}</p>
        {% if user and 'ROLE_ADMIN' in user.roles %}
            <p>
                <a class="button-link" href="{{ path('app_admin_parking_spot_index') }}">Miejsca postojowe</a>
                <a class="button-link" href="{{ path('app_admin_user_index') }}">Użytkownicy</a>
            </p>
        {% endif %}
    </main>
{% endblock %}
