{% extends 'base.html.twig' %}

{% block title %}SpotRace - rezerwacje{% endblock %}

{% block body %}
    <main class="card">
        <h1>Witaj, {{ user ? user.name : 'gościu' }}!</h1>
        <p>Zarządzaj rezerwacjami miejsc parkingowych.</p>
        {% if user and 'ROLE_ADMIN' in user.roles %}
            <p>
                <a class="button-link" href="{{ path('app_admin_parking_spot_index') }}">Miejsca postojowe</a>
                <a class="button-link" href="{{ path('app_admin_user_index') }}">Użytkownicy</a>
            </p>
        {% endif %}

        <h2>Dostępne miejsca (podział na dni)</h2>
        {% for day in freeDays %}
            <section>
                <h3>{{ day.date|date('Y-m-d') }}</h3>

                {% if day.assignment %}
                    <h4>Twoje przypisane miejsce</h4>
                    <p><strong>{{ day.assignment.parkingSpot.name }}</strong> ({{ day.assignment.parkingSpot.description }})</p>

                    {% if day.canConfirmAssigned %}
                        <form method="post" action="{{ path('app_reservation_confirm_assigned') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('confirm-assigned-' ~ day.date|date('Y-m-d')) }}">
                            <input type="hidden" name="date" value="{{ day.date|date('Y-m-d') }}">
                            <button type="submit">Potwierdź przypisane miejsce na {{ day.date|date('Y-m-d') }}</button>
                        </form>

                        <form method="post" action="{{ path('app_reservation_delegate_assigned') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delegate-assigned-' ~ day.date|date('Y-m-d')) }}">
                            <input type="hidden" name="date" value="{{ day.date|date('Y-m-d') }}">
                            <label for="target_user_id_{{ day.date|date('Ymd') }}">Przekaż miejsce innej osobie</label>
                            <select id="target_user_id_{{ day.date|date('Ymd') }}" name="target_user_id" required>
                                {% for managedUser in users %}
                                    {% if managedUser.id != user.id %}
                                        <option value="{{ managedUser.id }}">{{ managedUser.name }} ({{ managedUser.email }})</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <button type="submit">Przekaż miejsce</button>
                        </form>
                    {% endif %}
                {% endif %}

                {% if day.availableSpots is empty %}
                    <p>Brak wolnych miejsc.</p>
                {% else %}
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Miejsce</th>
                                <th>Opis</th>
                                <th>Akcja</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for spot in day.availableSpots %}
                                <tr>
                                    <td>{{ spot.name }}</td>
                                    <td>{{ spot.description }}</td>
                                    <td>
                                        <form class="inline-form" method="post" action="{{ path('app_reservation_free') }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reserve-free-' ~ day.date|date('Y-m-d')) }}">
                                            <input type="hidden" name="date" value="{{ day.date|date('Y-m-d') }}">
                                            <input type="hidden" name="spot_id" value="{{ spot.id }}">
                                            <button type="submit">Rezerwuj</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </section>
        {% endfor %}
    </main>
{% endblock %}
