<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}SpotRace{% endblock %}</title>
        <style>
            body {
                font-family: Arial, sans-serif;
                margin: 0;
                min-height: 100vh;
                display: grid;
                place-items: center;
                background: #101726;
                color: #f5f7fa;
            }
            .card {
                max-width: 720px;
                background: #1b2538;
                border-radius: 12px;
                padding: 2rem;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
            }
        </style>
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
