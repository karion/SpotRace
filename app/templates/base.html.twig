<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}SpotRace{% endblock %}</title>
        <style>
            body { font-family: Arial, sans-serif; margin: 0; min-height: 100vh; background: #101726; color: #f5f7fa; }
            .wrap { max-width: 1000px; margin: 2rem auto; padding: 0 1rem; }
            .card { background: #1b2538; border-radius: 12px; padding: 2rem; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25); }
            input, textarea, button { width: 100%; padding: .7rem; margin-top: .5rem; border-radius: 8px; border: 1px solid #2d3b57; background: #0f1728; color: #fff; box-sizing: border-box; }
            button { cursor: pointer; background: #2f66f6; border: none; margin-top: 1rem; }
            a { color: #8db1ff; }
            .flash { margin-bottom: .75rem; padding: .7rem; border-radius: 8px; }
            .flash-success { background: #214a31; }
            .flash-error { background: #5f1f2d; }
            .nav { display: flex; justify-content: space-between; margin-bottom: 1rem; align-items: center; }
            .logout-form { margin: 0; }
            .logout-form button { width: auto; padding: .5rem .75rem; margin-top: 0; }
            .button-link { display: inline-block; width: auto; padding: .45rem .75rem; border-radius: 8px; background: #2f66f6; color: #fff; text-decoration: none; margin-right: .4rem; }
            .inline-form { display: inline-block; margin: 0; }
            .inline-form button { width: auto; margin-top: 0; padding: .45rem .75rem; }
            .danger-btn { background: #b13b48; }
            .data-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
            .data-table th, .data-table td { border-bottom: 1px solid #2d3b57; text-align: left; vertical-align: top; padding: .6rem .3rem; }
        </style>
    </head>
    <body>
        <div class="wrap">
            <div class="nav">
                <a href="{{ path('app_home') }}">SpotRace</a>
                {% if app.user %}
                    <form class="logout-form" method="post" action="{{ path('app_logout') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button type="submit">Wyloguj</button>
                    </form>
                {% endif %}
            </div>
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </div>
    </body>
</html>
