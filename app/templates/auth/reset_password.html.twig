{% extends 'base.html.twig' %}

{% block title %}Nowe hasło{% endblock %}

{% block body %}
    <main class="card bg-body-tertiary shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 mb-4">Ustaw nowe hasło</h1>
            <form method="post" class="vstack gap-3">
                <div>
                    <label class="form-label">Nowe hasło</label>
                    <input class="form-control" type="password" name="password" required minlength="8" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" title="Minimum 8 znaków, co najmniej 1 wielka i mała litera oraz 1 cyfra">
                </div>
                <button class="btn btn-primary" type="submit">Zapisz hasło</button>
            </form>
        </div>
    </main>
{% endblock %}
