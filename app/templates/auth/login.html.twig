{% extends 'base.html.twig' %}

{% block title %}Logowanie{% endblock %}

{% block body %}
    <main class="card">
        <h1>Logowanie</h1>
        <form method="post">
            <label>Email</label>
            <input type="email" name="email" required>
            <label>Hasło</label>
            <input type="password" name="password" required>
            <button type="submit">Zaloguj</button>
        </form>
        <p><a href="{{ path('app_register') }}">Załóż konto</a></p>
        <p><a href="{{ path('app_forgot_password') }}">Nie pamiętasz hasła?</a></p>
    </main>
{% endblock %}
